{
  "wrapperId": "mckee-audio-wrapper",
  "mainId": "mckee-audio-block",
  "particleClass": "particles-container",
  "formWrapperClass": "contact-form-wrapper",
  "scopeClass": "mckee-audio-block",
  "ctaTitle": "Ready to Upgrade Your Audio-Visual Experience?",
  "ctaText": "Contact us for a free consultation. We'll help you design the perfect system for your home.",
  "html": "<div class=\"mckee-audio-wrapper\">\r\n<div class=\"mckee-audio-block\">\r\n    <!-- Floating Particles Background -->\r\n    <div class=\"particles-container\"></div>\r\n    <!-- Hero Section -->\r\n    <div class=\"hero\">\r\n        <div class=\"hero-content\">\r\n            <i class=\"fas fa-music hero-icon\"></i>\r\n            <h1>Audio / Video Installation</h1>\r\n            <p class=\"hero-tagline\">Your Certified Sonos Dealer for Modern Integrated Home Audio</p>\r\n            <p>We specialize in the installation of premium audio-visual systems, from simple TV wall mounts and sound bars to complete whole-home audio and immersive home theater experiences. Our team designs, installs, and configures systems that bring exceptional sound and picture quality to every room of your home.</p>\r\n            \r\n            <div class=\"hero-badges\">\r\n                <span class=\"hero-badge\"><i class=\"fas fa-certificate\"></i> Certified Sonos Dealer</span>\r\n                <span class=\"hero-badge\"><i class=\"fas fa-tv\"></i> TV & Soundbar Installation</span>\r\n                <span class=\"hero-badge\"><i class=\"fas fa-volume-up\"></i> Surround Sound Systems</span>\r\n                <span class=\"hero-badge\"><i class=\"fas fa-home\"></i> Whole-Home Audio</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Brand Showcase -->\r\n    <div class=\"brand-section\">\r\n        <h2>Premium Audio-Visual Brands</h2>\r\n        <p>We work exclusively with industry-leading brands to deliver exceptional audio and video experiences.</p>\r\n        \r\n        <div class=\"brand-grid\">\r\n            <div class=\"brand-item\">\r\n                <i class=\"fas fa-bullseye brand-logo\"></i>\r\n                <span class=\"brand-name\">Sonos</span>\r\n            </div>\r\n            <div class=\"brand-item\">\r\n                <i class=\"fas fa-tv brand-logo\"></i>\r\n                <span class=\"brand-name\">Samsung</span>\r\n            </div>\r\n            <div class=\"brand-item\">\r\n                <i class=\"fas fa-volume-up brand-logo\"></i>\r\n                <span class=\"brand-name\">Paradigm</span>\r\n            </div>\r\n            <div class=\"brand-item\">\r\n                <i class=\"fas fa-compact-disc brand-logo\"></i>\r\n                <span class=\"brand-name\">Anthem</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Services Header - Standalone -->\r\n    <div class=\"services-header\">\r\n        <h2>Our Audio-Visual Services</h2>\r\n        <p>From simple installations to complete entertainment systems, we handle it all.</p>\r\n    </div>\r\n\r\n    <!-- Services Showcase -->\r\n    <div class=\"services-showcase\">\r\n        <!-- TV & Soundbar Installation -->\r\n        <div class=\"service-row\">\r\n            <div class=\"service-visual\" style=\"background-image: url('https://mckeesecurity.ca/wp-content/uploads/2025/11/TV_Installation.png');\">\r\n                <i class=\"fas fa-tv service-visual-icon\"></i>\r\n            </div>\r\n            <div class=\"service-content\">\r\n                <h3><span class=\"service-icon\"><i class=\"fas fa-tools\"></i></span>TV & Soundbar Installation</h3>\r\n                <p>Professional wall-mounting services for TVs of all sizes. We ensure your television is securely mounted at the perfect viewing angle with clean, hidden cable management. Pair it with a Sonos soundbar for immersive audio that transforms your viewing experience.</p>\r\n                <div class=\"service-features\">\r\n                    <span class=\"service-feature\">Wall Mounting</span>\r\n                    <span class=\"service-feature\">Cable Concealment</span>\r\n                    <span class=\"service-feature\">Sonos Arc</span>\r\n                    <span class=\"service-feature\">Sonos Beam</span>\r\n                    <span class=\"service-feature\">Subwoofer Integration</span>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Whole Home Audio -->\r\n        <div class=\"service-row reverse\">\r\n            <div class=\"service-visual\" style=\"background-image: url('https://images.unsplash.com/photo-1556909114-f6e7ad7d3136?w=600&q=80');\">\r\n                <i class=\"fas fa-home service-visual-icon\"></i>\r\n            </div>\r\n            <div class=\"service-content\">\r\n                <h3><span class=\"service-icon\"><i class=\"fas fa-volume-up\"></i></span>Whole-Home Audio</h3>\r\n                <p>Transform your entire home into a connected audio experience. Using Sonos amps and premium in-ceiling or in-wall speakers, we create multi-room and multi-zone systems that let you enjoy music throughout your property. Control everything from your smartphone.</p>\r\n                <div class=\"service-features\">\r\n                    <span class=\"service-feature\">In-Ceiling Speakers</span>\r\n                    <span class=\"service-feature\">In-Wall Speakers</span>\r\n                    <span class=\"service-feature\">Sonos Amp</span>\r\n                    <span class=\"service-feature\">Multi-Zone Control</span>\r\n                    <span class=\"service-feature\">Pre-Wire Installation</span>\r\n                </div>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Home Theater -->\r\n        <div class=\"service-row\">\r\n            <div class=\"service-visual\" style=\"background-image: url('https://mckeesecurity.ca/wp-content/uploads/2025/11/Home_Theater.png');\">\r\n                <i class=\"fas fa-film service-visual-icon\"></i>\r\n            </div>\r\n            <div class=\"service-content\">\r\n                <h3><span class=\"service-icon\"><i class=\"fas fa-couch\"></i></span>Home Theater Experience</h3>\r\n                <p>Create the ultimate cinematic experience in your home. We design and install complete surround sound systems with premium speakers from Paradigm and receivers from Anthem. From 5.1 to immersive Dolby Atmos configurations, we bring the theater to you.</p>\r\n                <div class=\"service-features\">\r\n                    <span class=\"service-feature\">5.1 / 7.1 Surround</span>\r\n                    <span class=\"service-feature\">Dolby Atmos</span>\r\n                    <span class=\"service-feature\">Paradigm Speakers</span>\r\n                    <span class=\"service-feature\">Anthem Receivers</span>\r\n                    <span class=\"service-feature\">Acoustic Optimization</span>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- The Sonos & Sonance Ecosystem -->\r\n    <div class=\"products-section\">\r\n        <div class=\"products-header\">\r\n            <h2>The Sonos & Sonance Ecosystem</h2>\r\n            <p>As a certified Sonos dealer, we specialize in the complete product lineup including architectural speakers by Sonance.</p>\r\n        </div>\r\n        \r\n        <div class=\"product-grid\">\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/arcultra-anglehero-black.jpg\" alt=\"Sonos Arc Ultra\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Arc Ultra</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/ray-hero-black.jpg\" alt=\"Sonos Ray\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Ray</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/sub4-front-black.jpg\" alt=\"Sonos Sub 4\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Sub 4</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/era-100-front-white.jpg\" alt=\"Sonos Era 100\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Era 100</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/era-300-side-angle-white.jpg\" alt=\"Sonos Era 300\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Era 300</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/move2-front-black.jpg\" alt=\"Sonos Move 2\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Move 2</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/Sonos_Amp_White_03-1.jpg\" alt=\"Sonos Amp\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Sonos Amp</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/Sonance_In-Ceiling-Product_Render-Component_View.jpg\" alt=\"In-Ceiling Speakers\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">In-Ceiling</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/Sonance_In-Wall-Product_Render-Component_View.jpg\" alt=\"In-Wall Speakers\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">In-Wall</span>\r\n            </div>\r\n            <div class=\"product-item\">\r\n                <div class=\"product-image-wrapper\">\r\n                    <img decoding=\"async\" src=\"https://mckeesecurity.ca/wp-content/uploads/2025/11/Sonance_Group_with_Amp-Product_Render-Dark_Walls.jpg\" alt=\"Outdoor Speakers by Sonance\" class=\"product-image\">\r\n                </div>\r\n                <span class=\"product-name\">Outdoor Sonance</span>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Why Choose Us -->\r\n    <div class=\"featured-section\">\r\n        <div class=\"featured-content\">\r\n            <h2>Why Choose McKee Security for Audio-Visual?</h2>\r\n            <p>Professional installation ensures your system performs at its best and integrates seamlessly with your home.</p>\r\n            \r\n            <div class=\"card-grid two-col\">\r\n                <div class=\"card\">\r\n                    <h4><span class=\"card-icon\"><i class=\"fas fa-certificate\"></i></span>Certified Expertise</h4>\r\n                    <p>As a certified Sonos dealer, we have the training and experience to design, install, and configure your system for optimal performance. We understand the complete product ecosystem inside and out.</p>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h4><span class=\"card-icon\"><i class=\"fas fa-cogs\"></i></span>Custom Design</h4>\r\n                    <p>Every space is different. We assess your rooms, discuss your listening habits, and design a system tailored to your specific needs, whether it's a single soundbar or whole-home audio.</p>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h4><span class=\"card-icon\"><i class=\"fas fa-tools\"></i></span>Professional Installation</h4>\r\n                    <p>Clean, secure installations with hidden cables and properly configured equipment. We handle pre-wire installations, retrofit existing spaces, and ensure everything works perfectly before we leave.</p>\r\n                </div>\r\n\r\n                <div class=\"card\">\r\n                    <h4><span class=\"card-icon\"><i class=\"fas fa-headset\"></i></span>Ongoing Support</h4>\r\n                    <p>We're here to help long after the installation is complete. Need to add a room? Upgrade your system? Troubleshoot an issue? We've got you covered with responsive local support.</p>\r\n                </div>\r\n            </div>\r\n        </div>\r\n    </div>\r\n\r\n    <!-- Call to Action -->\r\n    <div class=\"cta-section\">\r\n        <h3>Ready to Upgrade Your Audio-Visual Experience?</h3>\r\n        <p>Contact us for a free consultation. We'll help you design the perfect system for your home.</p>\r\n        \r\n        <div class=\"cta-section\"><h3>Ready to Upgrade Your Audio-Visual Experience?</h3><p>Contact us for a free consultation. We'll help you design the perfect system for your home.</p><div class=\"contact-form-wrapper\" data-mckee-form=\"true\"></div></div></div>"
}